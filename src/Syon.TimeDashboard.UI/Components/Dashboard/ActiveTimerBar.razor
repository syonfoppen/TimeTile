@inherits FluxorComponent

@inject IState<TimerState> TimerState

@if (TimerState.Value.ActiveSession is not null)
{
    <div class="timer-bar">
        <div class="timer-info">
            <span class="timer-work-item">#@TimerState.Value.ActiveSession.WorkItemId</span>
            <span class="timer-title">@TimerState.Value.ActiveSession.WorkItemTitle</span>
        </div>
        <div class="timer-elapsed">@FormatElapsed(TimerState.Value.ActiveSession.Elapsed)</div>
        <button class="btn-stop" @onclick="StopTracking">&#9632; Stop</button>
    </div>
}

@code {
    [Inject] private IDispatcher Dispatcher { get; set; } = default!;

    private System.Threading.Timer? _tickTimer;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        _tickTimer = new System.Threading.Timer(_ =>
        {
            if (TimerState.Value.ActiveSession?.IsActive == true)
            {
                InvokeAsync(StateHasChanged);
            }
        }, null, TimeSpan.Zero, TimeSpan.FromSeconds(1));
    }

    private void StopTracking() => Dispatcher.Dispatch(new StopTrackingAction());

    private static string FormatElapsed(TimeSpan elapsed)
    {
        if (elapsed.TotalHours >= 1)
            return $"{(int)elapsed.TotalHours}:{elapsed.Minutes:D2}:{elapsed.Seconds:D2}";
        return $"{elapsed.Minutes:D2}:{elapsed.Seconds:D2}";
    }

    public void Dispose()
    {
        _tickTimer?.Dispose();
    }
}
