@page "/"
@inherits FluxorComponent

@inject IState<DashboardState> DashboardState
@inject IState<TimerState> TimerState
@inject IDispatcher Dispatcher

<div class="page-header">
    <h1 class="page-title">Dashboard</h1>
    <div class="page-header-actions">
        <button class="btn btn-outline" @onclick="PinMySprintTasks" disabled="@DashboardState.Value.IsPinningSprintTasks">
            <span>📌</span>
            <span>@(DashboardState.Value.IsPinningSprintTasks ? "Pinning…" : "Pin My Sprint")</span>
        </button>
        <button class="btn btn-primary" @onclick="OpenSearch">
            <span>+</span> Add Work Item
        </button>
    </div>
</div>

<FilterPanel />

@if (DashboardState.Value.IsLoading)
{
    <div style="display: flex; justify-content: center; padding: 48px;">
        <LoadingSpinner />
    </div>
}
else if (!string.IsNullOrEmpty(DashboardState.Value.ErrorMessage))
{
    <ErrorDisplay Message="@DashboardState.Value.ErrorMessage" OnRetry="LoadDashboard" />
}
else if (DashboardState.Value.Tiles.Count == 0)
{
    <EmptyState Icon="&#128204;" Message="No pinned work items" Hint="Click 'Add Work Item' to search and pin items to your dashboard">
        <button class="btn btn-primary" @onclick="OpenSearch">Search Work Items</button>
    </EmptyState>
}
else
{
    <TileGrid Tiles="DashboardState.Value.Tiles"
              ActiveWorkItemId="TimerState.Value.ActiveSession?.WorkItemId"
              RecentSessions="TimerState.Value.RecentSessions"
              OnStartTracking="StartTracking"
              OnStopTracking="StopTracking"
              OnUnpin="UnpinTile" />
}

@if (SearchState.Value.IsOpen)
{
    <SearchPanel />
}

@implements IDisposable

@code {
    [Inject] private IState<SearchState> SearchState { get; set; } = default!;

    private Timer? _refreshTimer;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        LoadDashboard();
        Dispatcher.Dispatch(new SyncTrackingStateAction());

        // Refresh tile data from AzDo every 60 seconds
        _refreshTimer = new Timer(_ =>
            InvokeAsync(() => Dispatcher.Dispatch(new RefreshTilesAction())),
            null, TimeSpan.FromSeconds(60), TimeSpan.FromSeconds(60));
    }

    private void LoadDashboard() => Dispatcher.Dispatch(new LoadDashboardAction());
    private void OpenSearch() => Dispatcher.Dispatch(new OpenSearchAction());
    private void StartTracking(int workItemId) => Dispatcher.Dispatch(new StartTrackingAction(workItemId));
    private void StopTracking() => Dispatcher.Dispatch(new StopTrackingAction());
    private void UnpinTile(int workItemId) => Dispatcher.Dispatch(new UnpinWorkItemAction(workItemId));
    private void PinMySprintTasks() => Dispatcher.Dispatch(new PinMySprintTasksAction());

    public void Dispose()
    {
        _refreshTimer?.Dispose();
    }
}
